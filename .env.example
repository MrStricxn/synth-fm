# Supabase auth + cloud sync. Copy to `.env.local` for dev and add the same
# vars to the Vercel project (Settings → Environment Variables) for prod.
# Both values are from Supabase: Project Settings → API.
# The anon key is public by design (Row Level Security protects the data).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Yandex.Music OAuth token (LOCAL DEV ONLY — used by the local proxy via the
# client). Get it by opening this URL, logging in, and copying the access_token
# from the redirected address bar (#access_token=...):
# https://oauth.yandex.ru/authorize?response_type=token&client_id=23cabbbdc6cd418abb4b39c32c41195d
VITE_YANDEX_TOKEN=

# CORS proxy base. Local dev: http://localhost:8080 (run `npm run proxy`) —
# the app defaults to this when the var is unset.
# Production: set this to your Yandex Cloud Function URL, e.g.
#   https://functions.yandexcloud.net/<function-id>
VITE_YANDEX_PROXY=http://localhost:8080

# PRODUCTION proxy: Yandex.Music geo-blocks (HTTP 451) every non-CIS IP, so the
# proxy CANNOT run on Vercel (US/EU). It runs on a Yandex Cloud Function in a
# Russian datacenter instead — see cloud/yandex-function/README.md.
# Set YANDEX_TOKEN (NO vite prefix) as an env var ON THE YANDEX CLOUD FUNCTION
# (not on Vercel). The function injects it server-side; it never reaches the
# browser bundle. Do NOT set VITE_YANDEX_TOKEN in production.
